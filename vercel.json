{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    { "src": "/door-showroom/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/door-showroom/uploads/(.*)", "dest": "/public/uploads/$1" },
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/uploads/(.*)", "dest": "/public/uploads/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
